@model FashionStoreAdmin.Models.CartCheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
}

<h1 class="h3 mb-3">Thanh toán</h1>

@if (TempData["SuccessMessage"] is string successMsg)
{
    <div class="alert alert-success">@successMsg</div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <form asp-action="Checkout" method="post" class="card border-0 shadow-sm">
            <div class="card-body">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="mb-3">
                    <label class="form-label">Tên</label>
                    <input class="form-control" asp-for="CustomerName" placeholder="Nhập họ tên" />
                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Số điện thoại</label>
                    <input class="form-control" asp-for="Phone" placeholder="Nhập số điện thoại" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Địa chỉ</label>
                    <textarea class="form-control" asp-for="Address" rows="3" placeholder="Nhập địa chỉ nhận hàng"></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Phương thức thanh toán</label>
                    <div class="d-flex gap-3 flex-wrap">
                        <label class="d-flex align-items-center gap-2">
                            <input type="radio" name="PaymentMethod" value="COD"
                                   @(Model.PaymentMethod == FashionStoreAdmin.Models.CartPaymentMethod.COD ? "checked" : "") />
                            <span>COD - Thanh toán khi nhận hàng</span>
                        </label>
                        <label class="d-flex align-items-center gap-2">
                            <input type="radio" name="PaymentMethod" value="QR"
                                   @(Model.PaymentMethod == FashionStoreAdmin.Models.CartPaymentMethod.QR ? "checked" : "") />
                            <span>QR - Thanh toán qua mã QR</span>
                        </label>
                    </div>
                    <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                </div>

                <div class="mt-3">
                    <button class="btn btn-primary w-100" type="submit">
                        <i class="fa-solid fa-credit-card me-2"></i> Đặt hàng
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <strong>Thông tin đơn hàng</strong>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span>Tổng tiền</span>
                    <span class="text-danger fw-bold">@Model.TotalAmount.ToString("N0") VND</span>
                </div>
                <hr />
                <div class="text-muted small">
                    Sau khi đặt hàng, hệ thống sẽ tạo đơn tương ứng với phương thức thanh toán bạn chọn.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}

