@model FashionStoreAdmin.Models.ClientOrdersViewModel
@{
    ViewData["Title"] = "Đơn hàng của tôi";
    string HienThiTrangThai(FashionStoreAdmin.Models.OrderStatus status) => status switch
    {
        FashionStoreAdmin.Models.OrderStatus.Pending => "Chờ xác nhận",
        FashionStoreAdmin.Models.OrderStatus.Confirmed => "Đã xác nhận",
        FashionStoreAdmin.Models.OrderStatus.Picking => "Đang lấy hàng",
        FashionStoreAdmin.Models.OrderStatus.Shipping => "Đang giao",
        FashionStoreAdmin.Models.OrderStatus.Completed => "Đã giao",
        FashionStoreAdmin.Models.OrderStatus.Cancelled => "Đã hủy",
        _ => status.ToString()
    };
}

<h1 class="h3 mb-3">Lịch sử mua hàng</h1>

@if (TempData["SuccessMessage"] is string msg)
{
    <div class="alert alert-success">@msg</div>
}

@if (Model.Orders.Count == 0)
{
    <div class="alert alert-info">Bạn chưa có đơn hàng nào.</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th>Sản phẩm</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model.Orders)
                    {
                        <tr>
                            <td>#@order.Id</td>
                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @string.Join(", ", order.Items.Select(i => $"{i.ProductName} ({i.Size}/{i.Color}) x{i.Quantity}"))
                            </td>
                            <td>@order.TotalAmount.ToString("N0") VND</td>
                            <td><span class="badge text-bg-info">@HienThiTrangThai(order.Status)</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
