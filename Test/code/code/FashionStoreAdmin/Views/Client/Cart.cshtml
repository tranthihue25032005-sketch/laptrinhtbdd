@model FashionStoreAdmin.Models.CartViewModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

<h1 class="h3 mb-3">Giỏ hàng</h1>

@if (Model.Items.Count == 0)
{
    <div class="alert alert-info">Giỏ hàng trống. <a asp-action="Products">Mua hàng ngay</a></div>
}
else
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Size/Màu</th>
                        <th>Đơn giá</th>
                        <th>Số lượng</th>
                        <th>Thành tiền</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ProductName</td>
                            <td>@item.Size / @item.Color</td>
                            <td>@item.UnitPrice.ToString("N0") VND</td>
                            <td style="width:170px">
                                <form asp-action="UpdateCart" method="post" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="hidden" name="size" value="@item.Size" />
                                    <input type="hidden" name="color" value="@item.Color" />
                                    <input type="number" class="form-control form-control-sm" name="quantity" min="0" value="@item.Quantity" />
                                    <button class="btn btn-sm btn-outline-primary">Lưu</button>
                                </form>
                            </td>
                            <td class="fw-bold">@((item.UnitPrice * item.Quantity).ToString("N0")) VND</td>
                            <td>
                                <form asp-action="RemoveFromCart" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="hidden" name="size" value="@item.Size" />
                                    <input type="hidden" name="color" value="@item.Color" />
                                    <button class="btn btn-sm btn-outline-danger">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Tổng tiền: <span class="text-danger">@Model.TotalAmount.ToString("N0") VND</span></h4>
        <a asp-controller="Cart" asp-action="Checkout" class="btn btn-success">Thanh toán</a>
    </div>
}
