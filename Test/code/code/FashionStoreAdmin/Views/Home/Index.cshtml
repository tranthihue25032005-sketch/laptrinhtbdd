@{
    ViewData["Title"] = "Trang chủ";
}

<div class="text-center py-5">
    <h1 class="display-5 fw-bold text-uppercase">
        <i class="fa-solid fa-store me-2"></i>CHÀO MỪNG BẠN ĐẾN VỚI TRANG QUẢN LÝ CỬA HÀNG THỜI TRANG
    </h1>
    <p class="lead text-uppercase">VUI LÒNG ĐĂNG NHẬP ĐỂ TRUY CẬP HỆ THỐNG QUẢN TRỊ.</p>
    <a class="btn btn-primary btn-lg text-uppercase fw-bold" asp-controller="Account" asp-action="Login">
        <i class="fa-solid fa-right-to-bracket me-2"></i>ĐĂNG NHẬP
    </a>
    <a class="btn btn-outline-dark btn-lg text-uppercase fw-bold ms-2" asp-controller="Client" asp-action="Index">
        <i class="fa-solid fa-bag-shopping me-2"></i>VÀO TRANG CLIENT
    </a>
</div>
